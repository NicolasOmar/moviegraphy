{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist", "coverage"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": "./",
    "paths": {
      "@api/*": ["prisma/api/*"],
      "@assets/*": ["src/assets/*"],
      "@components/*": ["src/components/*"],
      "@islands/*": ["src/islands/*"],
      "@layouts/*": ["src/layouts/*"],
      "@models": ["prisma/generated/models"],
      "@store/*": ["store/*"],
      "@ts/*": ["ts/*"]
    }
  }
}
