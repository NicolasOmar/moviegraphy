{
  "name": "moviegraphy",
  "version": "0.0.1",
  "description": "",
  "author": "Nicolás Omar González Passerino",
  "license": "GPL-3.0-only",
  "private": true,
  "homepage": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NicolasOmar/moviegraphy.git"
  },
  "bugs": {
    "url": "https://github.com/NicolasOmar/moviegraphy/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "prepare": "husky",
    "lint:base": "eslint src/**/*.{ts,tsx,astro} {prisma,ts}/**/*.ts",
    "lint": "npm run lint:base -- --max-warnings 0",
    "lint:fix": "npm run lint:base -- --fix",
    "format:base": "prettier src/**/*.{ts,tsx,astro} {prisma,ts}/**/*.ts",
    "format": "npm run format:base -- --write",
    "format:check": "npm run format:base -- --check",
    "lint-staged": "lint-staged -v",
    "db:generate": "prisma format && prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "update": "npm run update:astro && npm run update:deps",
    "update:astro": "npx @astrojs/upgrade",
    "update:deps": "ncu -i --format group --doctor --doctorTest 'npm run check:project'",
    "check:project": "npm run format:check && npm run lint && npm run db:generate && npm run build"
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "@astrojs/check": "^0.9.9",
    "@astrojs/netlify": "^8.1.2",
    "@astrojs/react": "^6.0.1",
    "@nanostores/react": "^1.1.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "antd": "^6.5.1",
    "astro": "^7.0.9",
    "dotenv": "^17.4.2",
    "nanostores": "^1.4.0",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^9.39.4",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-perfectionist": "^5.10.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "npm-check-updates": "^22.2.9",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "prisma": "^7.8.0",
    "tsx": "^4.23.1",
    "typescript-eslint": "^8.64.0"
  },
  "lint-staged": {
    "(prisma|ts|src)/**/*.(astro|ts|tsx)": [
      "prettier --write",
      "eslint --max-warnings 0"
    ]
  }
}
