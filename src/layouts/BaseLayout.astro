---
import { ReactLayout } from '@components/shared/ReactLayout'

const listOfLinks = [
  { key: 'home', label: 'Home', link: '/' },
  { key: 'movies', label: 'Movies', link: '/movies' },
  { key: 'users', label: 'Users', link: '/users' }
]
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width" name="viewport" />
    <link href="/favicon.svg" rel="icon" type="image/svg+xml" />
    <link href="/favicon.ico" rel="icon" />
    <meta content={Astro.generator} name="generator" />
    <title>Moviegraphy</title>
  </head>
  <body>
    <ReactLayout client:load listOfLinks={listOfLinks}>
      <slot />
    </ReactLayout>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
